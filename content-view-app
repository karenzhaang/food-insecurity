                .padding(.vertical, 16).padding(.trailing, 16).padding(.leading, 0)
                .background(Color.warmPaper)
                .padding(.horizontal, 20).padding(.top, 12)
                .opacity(appeared ? 1 : 0)
                .animation(.easeOut(duration: 0.5).delay(0.65), value: appeared)
                
                Button(action: { Haptics.impact(); onReset() }) {
                    HStack(spacing: 8) {
                        Image(systemName: "arrow.counterclockwise")
                        Text("Try Again")
                    }
                    .font(.system(size: 14, weight: .black, design: .monospaced))
                    .foregroundColor(.warmPaper)
                    .padding(.horizontal, 36).padding(.vertical, 14)
                    .background(Color.inkBlack)
                }
                .padding(.top, 28).padding(.bottom, 50)
                .opacity(appeared ? 1 : 0)
                .animation(.easeOut(duration: 0.5).delay(0.75), value: appeared)
            }
        }
        .onAppear { appeared = true }
    }
}
