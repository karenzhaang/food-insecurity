// Scales icon
struct ScalesIcon: View {
    var color: Color = .inkBlack
    var size: CGFloat = 32
    var body: some View {
        Canvas { ctx, sz in
            let s = sz.width / 32
            var beam = Path()
            beam.move(to: CGPoint(x: 4*s, y: 12*s)); beam.addLine(to: CGPoint(x: 28*s, y: 12*s))
            ctx.stroke(beam, with: .color(color), style: StrokeStyle(lineWidth: 1.7*s, lineCap: .round))
            var post = Path()
            post.move(to: CGPoint(x: 16*s, y: 4*s)); post.addLine(to: CGPoint(x: 16*s, y: 30*s))
            ctx.stroke(post, with: .color(color), style: StrokeStyle(lineWidth: 1.5*s))
            var base = Path()
            base.move(to: CGPoint(x: 10*s, y: 30*s)); base.addLine(to: CGPoint(x: 22*s, y: 30*s))
            ctx.stroke(base, with: .color(color), style: StrokeStyle(lineWidth: 1.7*s, lineCap: .round))
            // pans
            let panPts: [(CGFloat, CGFloat)] = [(4, 12), (28, 12)]
            for (px, py) in panPts {
                var pan = Path()
                pan.move(to: CGPoint(x: (px-5)*s, y: py*s))
                pan.addQuadCurve(to: CGPoint(x: (px+5)*s, y: py*s),
                                 control: CGPoint(x: px*s, y: (py+7)*s))
                ctx.stroke(pan, with: .color(color), style: StrokeStyle(lineWidth: 1.5*s, lineCap: .round))
            }
        }
        .frame(width: size, height: size)
    }
}

