// MARK: - Live Counter ViewModel

@MainActor
class HungerCounterViewModel: ObservableObject {
    @Published var count: Int = 0
    @Published var deathCount: Double = 0.0
    private var timer: AnyCancellable?
    private let startTime = Date()
    private let mealSkipsPerSecond: Double = 23148.0
    private let deathsPerSecond: Double = 0.289
    
    func start() {
        timer = Timer.publish(every: 0.05, on: .main, in: .common)
            .autoconnect()
            .sink { [weak self] _ in
                guard let self else { return }
                let elapsed = Date().timeIntervalSince(self.startTime)
                self.count = Int(elapsed * self.mealSkipsPerSecond)
                self.deathCount = elapsed * self.deathsPerSecond
            }
    }
    func stop() { timer?.cancel() }
}

// MARK: - Budget ViewModel

@MainActor
class BudgetViewModel: ObservableObject {
    let dailyBudget: Double = 5.0
    @Published var allocations: [UUID: Double] = [:]
    
    let items: [BudgetItem] = [
        BudgetItem(icon: AnyView(BreadIcon(color: .inkBlack, size: 26)), name: "Bread & Grains",  minimumCost: 1.50, description: "Rice, bread, pasta — caloric staples"),
        BudgetItem(icon: AnyView(MilkIcon(color: .inkBlack, size: 26)), name: "Dairy / Protein", minimumCost: 1.80, description: "Eggs, beans, peanut butter, or milk"),
        BudgetItem(icon: AnyView(LeafIcon(color: .inkBlack, size: 26)), name: "Vegetables",      minimumCost: 1.20, description: "Fresh produce — often unaffordable"),
        BudgetItem(icon: AnyView(AppleIcon(color: .inkBlack, size: 26)), name: "Fruit",           minimumCost: 1.00, description: "Nutritional but costly relative to calories"),
        BudgetItem(icon: AnyView(WaterIcon(color: .inkBlack, size: 26)), name: "Clean Water",     minimumCost: 0.50, description: "Safe drinking water — not free everywhere"),
    ]
    
    var totalSpent: Double { allocations.values.reduce(0, +) }
    var remaining: Double { dailyBudget - totalSpent }
    
    var score: BudgetScore {
        let met = items.filter { (allocations[$0.id] ?? 0) >= $0.minimumCost }.count
        switch met {
        case 5: return .thriving
        case 3, 4: return .surviving
        case 1, 2: return .struggling
        default: return .crisis
        }
    }
    
    func allocation(for item: BudgetItem) -> Double { allocations[item.id] ?? 0 }
    func setAllocation(_ value: Double, for item: BudgetItem) {
        allocations[item.id] = min(max(0, value), dailyBudget)
    }
    func reset() { allocations = [:] }
    
    enum BudgetScore {
        case thriving, surviving, struggling, crisis
        var stampText: String {
            switch self {
            case .thriving:  return "STABLE"
            case .surviving: return "FRAGILE"
            case .struggling: return "DEFICIT"
            case .crisis:    return "CRISIS"
            }
        }
        var title: String {
            switch self {
            case .thriving:  return "Barely Balanced"
            case .surviving: return "Compromising Nutrition"
            case .struggling: return "Going Without"
            case .crisis:    return "In Crisis"
            }
        }
        var message: String {
            switch self {
            case .thriving: return "You managed to cover all basics on $5 — but there's zero margin. One sick day, one bus fare, one unexpected cost and it collapses entirely."
            case .surviving: return "You covered most needs but had to skip some. That means lower energy, weaker immunity, and harder time concentrating at work or school."
            case .struggling: return "You could only afford 1–2 food groups. This is chronic malnutrition — the kind that stunts children's growth and shortens lives."
            case .crisis: return "You went without food entirely. For 733 million people, this is not a simulation — it's Tuesday."
            }
        }
        var color: Color {
            switch self {
            case .thriving:  return Color.greenStamp
            case .surviving: return Color.amberWarn
            case .struggling: return Color.redInk
            case .crisis:    return Color(red: 0.55, green: 0.05, blue: 0.02)
            }
        }
    }
}

