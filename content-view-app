// Wheat stalk
struct WheatIcon: View {
    var color: Color = .inkBlack
    var size: CGFloat = 32
    var body: some View {
        Canvas { ctx, sz in
            let s = sz.width / 32
            // stem
            var stem = Path()
            stem.move(to: CGPoint(x: 16*s, y: 30*s))
            stem.addCurve(to: CGPoint(x: 16*s, y: 4*s),
                          control1: CGPoint(x: 13*s, y: 22*s),
                          control2: CGPoint(x: 19*s, y: 12*s))
            ctx.stroke(stem, with: .color(color), style: StrokeStyle(lineWidth: 1.8*s, lineCap: .round))
            // grain clusters
            for i in 0..<4 {
                let y = CGFloat(8 + i * 5) * s
                var left = Path()
                left.move(to: CGPoint(x: 16*s, y: y))
                left.addQuadCurve(to: CGPoint(x: 9*s, y: y - 2*s), control: CGPoint(x: 12*s, y: y - 4*s))
                ctx.stroke(left, with: .color(color), style: StrokeStyle(lineWidth: 1.5*s, lineCap: .round))
                var right = Path()
                right.move(to: CGPoint(x: 16*s, y: y))
                right.addQuadCurve(to: CGPoint(x: 23*s, y: y - 2*s), control: CGPoint(x: 20*s, y: y - 4*s))
                ctx.stroke(right, with: .color(color), style: StrokeStyle(lineWidth: 1.5*s, lineCap: .round))
            }
        }
        .frame(width: size, height: size)
    }
}

