struct TrendLineView: View {
    let animate: Bool
    let data: [(year: Int, value: Double)] = [
        (2015,607),(2016,613),(2017,624),(2018,638),(2019,648),(2020,720),(2021,730),(2022,735),(2023,733),(2024,733)
    ]
    var minV: Double { data.map(\.value).min()! }
    var maxV: Double { data.map(\.value).max()! }
    
    func pts(w: CGFloat, h: CGFloat, pad: CGFloat) -> [CGPoint] {
        data.enumerated().map { i, d in
            let xRatio = CGFloat(i) / CGFloat(data.count - 1)
            let yRatio = CGFloat((d.value - minV) / (maxV - minV))
            return CGPoint(
                x: pad + (w - pad * 2) * xRatio,
                y: h - pad - (h - pad * 2) * yRatio
            )
        }
    }
    
    var body: some View {
        GeometryReader { geo in
            let w = geo.size.width; let h = geo.size.height; let pad: CGFloat = 28
            ZStack(alignment: .topLeading) {
                Color.warmPaper
                Canvas { ctx, sz in
                    for y in stride(from: 0, to: sz.height, by: 18) {
                        var line = Path()
                        line.move(to: CGPoint(x: 0, y: y))
                        line.addLine(to: CGPoint(x: sz.width, y: y))
                        ctx.stroke(line, with: .color(Color.newsprint.opacity(0.5)), lineWidth: 0.5)
                    }
                }
                
                // Grid lines
                ForEach([600, 640, 680, 720], id: \.self) { val in
                    let yRatio = CGFloat((Double(val) - minV) / (maxV - minV))
                    let y = h - pad - (h - pad * 2) * yRatio
                    Path { p in p.move(to: CGPoint(x: pad, y: y)); p.addLine(to: CGPoint(x: w - pad, y: y)) }
                        .stroke(Color.inkBlack.opacity(0.08), style: StrokeStyle(lineWidth: 1, dash: [4, 4]))
                    Text("\(val)M")
                        .font(.system(size: 7, design: .monospaced))
                        .foregroundColor(.fadedInk.opacity(0.45))
                        .position(x: pad + 14, y: y - 8)
                }
                
                // Area fill
                Path { p in
                    let points = pts(w: w, h: h, pad: pad)
                    guard let first = points.first else { return }
                    p.move(to: CGPoint(x: first.x, y: h - pad))
                    for pt in points { p.addLine(to: pt) }
                    if let last = points.last { p.addLine(to: CGPoint(x: last.x, y: h - pad)) }
                    p.closeSubpath()
                }
                .fill(Color.redInk.opacity(0.1))
                .opacity(animate ? 1 : 0)
                .animation(.easeIn(duration: 0.6).delay(0.4), value: animate)
                
                // Line
                TrendPath(points: pts(w: w, h: h, pad: pad), progress: animate ? 1.0 : 0.0)
                    .stroke(Color.redInk, style: StrokeStyle(lineWidth: 2, lineCap: .round, lineJoin: .round))
                    .animation(.easeInOut(duration: 1.2).delay(0.2), value: animate)
                
                // Dots + year labels
                ForEach(Array(data.enumerated()), id: \.offset) { i, d in
                    let points = pts(w: w, h: h, pad: pad)
                    if i < points.count {
                        let pt = points[i]
                        Circle().fill(Color.redInk).frame(width: 5, height: 5).position(pt)
                            .opacity(animate ? 1 : 0)
                            .animation(.easeIn(duration: 0.2).delay(Double(i)*0.08 + 0.6), value: animate)
                        if i % 2 == 0 {
                            Text("\(d.year)")
                                .font(.system(size: 7, design: .monospaced))
                                .foregroundColor(.fadedInk.opacity(0.5))
                                .position(x: pt.x, y: h - 10)
                        }
                    }
                }
                
                // COVID annotation — handwritten-ish
                Text("▲ COVID SURGE")
                    .font(.system(size: 8, weight: .black, design: .monospaced))
                    .foregroundColor(Color.redInk.opacity(0.6))
                    .position(x: w * 0.575, y: 14)
                    .opacity(animate ? 1 : 0)
                    .animation(.easeIn.delay(1.2), value: animate)
            }
        }
        .clipShape(RoundedRectangle(cornerRadius: 4))
        .overlay(Rectangle().stroke(Color.inkBlack.opacity(0.12), lineWidth: 1))
    }
}

struct TrendPath: Shape {
    var points: [CGPoint]
    var progress: Double
    var animatableData: Double {
        get { progress }
        set { progress = newValue }
    }
    func path(in rect: CGRect) -> Path {
        var p = Path()
        guard points.count > 1 else { return p }
        let count = max(2, Int(Double(points.count - 1) * progress) + 1)
        p.move(to: points[0])
        for i in 1..<count { p.addLine(to: points[i]) }
        return p
    }
}

